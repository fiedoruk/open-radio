{
  "name": "open-radio-core2",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "simulator": "node scripts/serve-simulator.mjs",
    "validate:gui": "node scripts/validate-gui-contract.mjs",
    "validate:ui": "node scripts/validate-ui-contract.mjs",
    "validate:catalog": "node scripts/validate-station-catalog.mjs",
    "catalog:refresh": "node scripts/catalog-refresh.mjs",
    "validate:catalog-packs": "node scripts/validate-catalog-pack.mjs",
    "validate:persistence": "node scripts/validate-persistence-contract.mjs",
    "validate:network": "node scripts/validate-network-contract.mjs",
    "audit:overflow": "node scripts/audit-ui-overflow.mjs",
    "qa:gui": "npm run validate:gui && npm run validate:catalog-packs && npm run audit:overflow && node --test tests/gui-lab.test.mjs tests/simulator-state.test.mjs tests/catalog-resolver.test.mjs",
    "generate:font": "python3 scripts/generate-inter-font.py",
    "generate:font:check": "python3 scripts/generate-inter-font.py --check",
    "generate:kiara": "python3 scripts/generate-kiara-sprite.py",
    "generate:kiara:check": "python3 scripts/generate-kiara-sprite.py --check",
    "generate:renderer": "node scripts/generate-renderer-contract.mjs --write",
    "generate:renderer:check": "node scripts/generate-renderer-contract.mjs",
    "build:renderer": "make -C renderer host",
    "test:renderer": "make -C renderer test",
    "generate:renderer:evidence": "node scripts/check-renderer-determinism.mjs --write",
    "check:renderer": "npm run generate:font:check && npm run generate:kiara:check && npm run generate:renderer:check && make -C renderer test determinism",
    "generate:resolver": "node scripts/generate-resolver-traces.mjs --write",
    "generate:resolver:check": "node scripts/generate-resolver-traces.mjs",
    "simulate:resolver": "node scripts/run-resolver-simulator.mjs",
    "generate:persistence": "node scripts/generate-persistence-traces.mjs --write",
    "generate:persistence:check": "node scripts/generate-persistence-traces.mjs",
    "simulate:persistence": "node scripts/run-persistence-simulator.mjs",
    "generate:network": "node scripts/generate-network-traces.mjs --write",
    "generate:network:check": "node scripts/generate-network-traces.mjs",
    "simulate:network": "node scripts/run-network-simulator.mjs",
    "generate:firmware": "node scripts/generate-firmware-assets.mjs",
    "generate:firmware:check": "node scripts/generate-firmware-assets.mjs --check",
    "generate:firmware:services": "node scripts/generate-firmware-service-vectors.mjs",
    "generate:firmware:services:check": "node scripts/generate-firmware-service-vectors.mjs --check",
    "generate:runtime": "node scripts/generate-runtime-contract.mjs",
    "generate:runtime:check": "node scripts/generate-runtime-contract.mjs --check",
    "simulate:runtime": "node scripts/run-runtime-soaks.mjs",
    "generate:ingress": "node scripts/generate-ingress-contract.mjs",
    "generate:ingress:check": "node scripts/generate-ingress-contract.mjs --check",
    "simulate:ingress": "node scripts/run-ingress-traces.mjs",
    "validate:community": "node scripts/validate-community-evidence.mjs",
    "replay:community": "node scripts/replay-community-trace.mjs",
    "check:docs-parity": "node scripts/check-docs-parity.mjs",
    "check:doc-currency": "node scripts/check-doc-currency.mjs",
    "rehearse:rc1": "node scripts/rehearse-rc1-source.mjs --check",
    "rehearse:rc1:write": "node scripts/rehearse-rc1-source.mjs --write",
    "test:firmware:host": "make -C firmware/common test",
    "check:ui-controller-parity": "node scripts/check-ui-controller-parity.mjs",
    "check:firmware:lock": "node scripts/check-firmware-lock.mjs",
    "check:firmware:surface": "node scripts/check-firmware-surface.mjs",
    "check:audio-surface": "node scripts/check-audio-surface.mjs",
    "check:audio-surface:write": "node scripts/check-audio-surface.mjs --write",
    "check:hardware-readiness": "node scripts/check-hardware-readiness.mjs",
    "check:hardware-readiness:write": "node scripts/check-hardware-readiness.mjs --write-development-surface",
    "verify:device:boot": "node scripts/verify-device-boot.mjs",
    "capture:hardware:soak": "node scripts/capture-hardware-soak.mjs",
    "build:firmware:public": "bash scripts/build-firmware-public.sh",
    "build:firmware:owner": "bash scripts/build-firmware-owner.sh",
    "build:firmware:variants": "bash scripts/build-firmware-variants.sh",
    "collect:firmware:s8": "node scripts/collect-s8-evidence.mjs",
    "collect:firmware:s9": "node scripts/collect-s9-evidence.mjs",
    "collect:firmware:s10": "node scripts/collect-s10-evidence.mjs",
    "rehearse:firmware:release": "node scripts/rehearse-firmware-release.mjs",
    "test": "node scripts/run-node-tests.mjs",
    "check": "npm run validate:gui && npm run validate:ui && npm run validate:catalog && npm run validate:catalog-packs && npm run validate:persistence && npm run validate:network && npm run generate:resolver:check && npm run generate:persistence:check && npm run generate:network:check && npm run generate:firmware:check && npm run generate:firmware:services:check && npm run generate:runtime:check && npm run generate:ingress:check && npm run validate:community && npm run check:docs-parity && npm run check:doc-currency && npm run check:public-mirror && npm run check:firmware:lock && npm run check:firmware:surface && npm run check:audio-surface && npm run check:hardware-readiness && npm run audit:overflow && npm run check:renderer && npm run check:ui-controller-parity && npm run test:firmware:host && npm test && npm run rehearse:rc1",
    "check:public-mirror": "node scripts/check-public-mirror.mjs",
    "publish:mirror": "bash scripts/publish-public-mirror.sh"
  }
}
