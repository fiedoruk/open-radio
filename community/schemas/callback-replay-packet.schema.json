{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiedoruk.pl/open-radio/schemas/callback-replay-packet.schema.json",
  "title": "CallbackReplayPacket",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "reportType", "firmwareSha256", "traceId", "facts"],
  "properties": {
    "schemaVersion": {"const": 1},
    "reportType": {"const": "CALLBACK_REPLAY"},
    "firmwareSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "traceId": {"type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"},
    "facts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["producer", "epoch", "producerSequence", "rawTick", "type"],
        "properties": {
          "producer": {"enum": ["STORAGE", "WIFI", "RESOLVER", "STREAM", "BLUETOOTH", "LOCAL_OUTPUT", "POWER"]},
          "epoch": {"type": "integer", "minimum": 1, "maximum": 4294967295},
          "producerSequence": {"type": "integer", "minimum": 1, "maximum": 4294967295},
          "rawTick": {"type": "integer", "minimum": 0, "maximum": 4294967295},
          "type": {"enum": ["CONFIG_MISSING", "CONFIG_CORRUPT", "CONFIG_READY", "WIFI_CONNECTED", "WIFI_LOST", "RESOLVER_READY", "RESOLVER_UNSUPPORTED", "STREAM_HEALTHY", "STREAM_STALLED", "BLUETOOTH_REMEMBERED", "BLUETOOTH_CONNECTED", "BLUETOOTH_LOST", "LOCAL_OUTPUT_AVAILABLE", "LOCAL_OUTPUT_LOST", "POWER_INTERRUPTED"]}
        }
      }
    }
  }
}
