{
  "schemaVersion": 1,
  "writePhases": ["BEFORE_WRITE", "DURING_PAYLOAD", "BEFORE_COMMIT_MARKER", "AFTER_COMMIT"],
  "slotRejections": ["EMPTY", "ENVELOPE_INVALID", "UNCOMMITTED", "CHECKSUM_MISMATCH", "PAYLOAD_PARSE_ERROR", "CONFIG_INVALID", "LEGACY_CONFIG_INVALID", "FUTURE_SCHEMA_UNSUPPORTED"],
  "safeModeReasons": ["CONFIG_UNAVAILABLE", "BOOT_LOOP"],
  "bootFailureThreshold": 3
}
