{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://fiedoruk.pl/open-radio-core2/schemas/device-config-v2.schema.json",
  "title":"DeviceConfigV2",
  "type":"object",
  "required":["schemaVersion","locale","preferredStationId","volume","brightness","theme","nowPlayingVariant","display","wifiProfileRefs","bluetoothDeviceRef","city","onboardingComplete"],
  "properties":{
    "schemaVersion":{"const":2},
    "locale":{"enum":["pl","en"]},
    "preferredStationId":{"type":"string","minLength":3,"maxLength":64},
    "volume":{"type":"integer","minimum":0,"maximum":100},
    "brightness":{"type":"integer","minimum":0,"maximum":100},
    "theme":{"enum":["dark","light"]},
    "nowPlayingVariant":{"enum":["editorial","glance"]},
    "display":{
      "type":"object",
      "required":["screensaverEnabled","screensaverMode","screensaverDelaySeconds","displayOffEnabled","displayOffDelaySeconds"],
      "properties":{
        "screensaverEnabled":{"type":"boolean"},
        "screensaverMode":{"enum":["pulse","bars","orbit"]},
        "screensaverDelaySeconds":{"enum":[30,60,120,300,600]},
        "displayOffEnabled":{"type":"boolean"},
        "displayOffDelaySeconds":{"enum":[900,1800,3600]}
      },
      "additionalProperties":false
    },
    "wifiProfileRefs":{"type":"array","minItems":1,"maxItems":8,"uniqueItems":true,"items":{"type":"string","minLength":6,"maxLength":53}},
    "bluetoothDeviceRef":{"type":["string","null"],"minLength":4,"maxLength":51},
    "city":{
      "type":"object",
      "required":["mode","label"],
      "properties":{
        "mode":{"enum":["AUTO_APPROXIMATE","MANUAL","DISABLED"]},
        "label":{"type":["string","null"],"minLength":1,"maxLength":64}
      },
      "additionalProperties":false
    },
    "onboardingComplete":{"type":"boolean"}
  },
  "additionalProperties":false
}
