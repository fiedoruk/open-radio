{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiedoruk.pl/open-radio-core2/schemas/catalog-pack.schema.json",
  "title": "CatalogPack",
  "type": "object",
  "required": ["schemaVersion","packId","countryCode","defaultUiLocale","supportedUiLocales","regionLabels","stationCatalogPath","stationIdentityPath","maximumStations","remoteUpdate","runtimeInstall"],
  "properties": {
    "schemaVersion": {"const":1},
    "packId": {"type":"string","minLength":3,"maxLength":64,"pattern":"^[a-z0-9][a-z0-9.-]+$"},
    "countryCode": {"type":"string","pattern":"^[A-Z]{2}$"},
    "defaultUiLocale": {"type":"string","minLength":2,"maxLength":16},
    "supportedUiLocales": {"type":"array","minItems":1,"maxItems":8,"uniqueItems":true,"items":{"type":"string","minLength":2,"maxLength":16}},
    "regionLabels": {"type":"object","minProperties":1,"additionalProperties":{"type":"string","minLength":2,"maxLength":48}},
    "stationCatalogPath": {"type":"string","minLength":8,"maxLength":160,"pattern":"^ui-contract/catalog/(?!.*\\.\\.)[A-Za-z0-9._/-]+\\.json$"},
    "stationIdentityPath": {"type":"string","minLength":8,"maxLength":160,"pattern":"^ui-contract/gui/(?!.*\\.\\.)[A-Za-z0-9._/-]+\\.json$"},
    "maximumStations": {"const":9},
    "remoteUpdate": {"const":false},
    "runtimeInstall": {"const":false}
  },
  "additionalProperties": false
}
