{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://fiedoruk.pl/open-radio-core2/schemas/network-selection.schema.json",
  "title":"NetworkSelection",
  "type":"object",
  "required":["schemaVersion","status","selectedProfileRef","retryAtMs","trace"],
  "properties":{
    "schemaVersion":{"const":1},
    "status":{"enum":["SELECTED","PROMPT_REQUIRED","RETRY_SCHEDULED"]},
    "selectedProfileRef":{"type":["string","null"],"minLength":6,"maxLength":53},
    "retryAtMs":{"type":["integer","null"],"minimum":0},
    "trace":{
      "type":"array","minItems":1,"maxItems":64,
      "items":{
        "type":"object",
        "required":["scanId","profileRef","decision","reason","score"],
        "properties":{
          "scanId":{"type":"string","minLength":6,"maxLength":53},
          "profileRef":{"type":["string","null"],"minLength":6,"maxLength":53},
          "decision":{"enum":["REJECT","PROMPT","CANDIDATE","SELECT"]},
          "reason":{"type":["string","null"],"minLength":3,"maxLength":64},
          "score":{"type":["integer","null"]}
        },
        "additionalProperties":false
      }
    }
  },
  "additionalProperties":false
}
