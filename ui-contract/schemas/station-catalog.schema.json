{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiedoruk.pl/open-radio-core2/schemas/station-catalog.schema.json",
  "title": "StationCatalog",
  "type": "object",
  "required": ["schemaVersion","catalogId","auditedAt","lifecycle","remoteUpdate","bitrateCeilingKbps","stations"],
  "properties": {
    "schemaVersion": {"const":1},
    "catalogId": {"type":"string","minLength":3,"maxLength":64},
    "auditedAt": {"type":"string","minLength":10,"maxLength":10},
    "lifecycle": {"const":"EMBEDDED_STATIC"},
    "remoteUpdate": {"const":false},
    "bitrateCeilingKbps": {"type":"integer","minimum":64,"maximum":320},
    "stations": {
      "type":"array","minItems":1,"maxItems":9,
      "items": {
        "type":"object",
        "required":["id","displayName","operator","operatorGroup","country","language","regionMode","regionalSelection","capabilityClass","firmwareSupport","artworkRights","nameUse","officialSurface","candidates","playback"],
        "properties": {
          "id":{"type":"string","minLength":3,"maxLength":64},
          "displayName":{"type":"string","minLength":2,"maxLength":64},
          "operator":{"type":"string","minLength":2,"maxLength":128},
          "operatorGroup":{"type":"string","minLength":2,"maxLength":128},
          "country":{"type":"string","pattern":"^[A-Z]{2}$"},
          "language":{"type":"string","minLength":2,"maxLength":16},
          "regionMode":{"enum":["national","supraregional","regional","national-online","internet-only"]},
          "regionalSelection":{"enum":["NONE","OPTIONAL"]},
          "capabilityClass":{"enum":["MP3_ICY","HLS_HE_AAC"]},
          "firmwareSupport":{"enum":["MODEL_READY","PARSER_PENDING","DECODER_PENDING"]},
          "artworkRights":{"const":"PROJECT_ORIGINAL_ONLY"},
          "nameUse":{"const":"IDENTIFICATION_ONLY"},
          "officialSurface":{"type":"string","minLength":12,"maxLength":512},
          "favicon":{"type":["string","null"],"maxLength":160},
          "candidates":{"type":"array","minItems":2,"maxItems":4,"items":{"type":"object"}},
          "playback":{"type":"array","minItems":1,"maxItems":6,"items":{
            "type":"object",
            "required":["id","url","transport","bitrateKbps","resolver","verifiedAt","evidence"],
            "properties":{
              "id":{"type":"string","minLength":3,"maxLength":64},
              "url":{"type":"string","minLength":12,"maxLength":127},
              "transport":{"const":"MP3_ICY"},
              "bitrateKbps":{"type":"integer","minimum":32,"maximum":320},
              "resolver":{"enum":["DIRECT","RMFON_POOL"]},
              "verifiedAt":{"type":"string","minLength":10,"maxLength":10},
              "evidence":{"type":"string","minLength":3,"maxLength":128}
            },
            "additionalProperties":false
          }}
        },
        "additionalProperties":false
      }
    }
  },
  "additionalProperties":false
}
