{
  "schemaVersion": 1,
  "candidate": "open-radio-core2-rc1-source",
  "sourceOnly": true,
  "include": [
    ".github",
    ".gitignore",
    "AUTHORS.md",
    "brand",
    "CITATION.cff",
    "CONTRIBUTING.md",
    "CONTRIBUTING.pl.md",
    "GOVERNANCE.md",
    "LICENSE",
    "LICENSES.md",
    "NETWORK-ENDPOINTS.md",
    "NOTICE",
    "README.md",
    "README.pl.md",
    "REPRODUCIBILITY.md",
    "REPRODUCIBILITY.pl.md",
    "SECURITY.md",
    "SUPPORT.md",
    "SUPPORT.pl.md",
    "THIRD-PARTY-NOTICES.md",
    "TRADEMARKS.md",
    "community",
    "decisions",
    "docs",
    "firmware",
    "gui-lab",
    "hardware",
    "network",
    "network-onboarding",
    "package.json",
    "persistence",
    "release",
    "renderer",
    "resolver",
    "runtime",
    "scripts",
    "simulator",
    "tests",
    "third_party",
    "ui-contract"
  ],
  "excludedSegments": [".git", ".pio", ".tools", ".playwright-cli", ".cache", "build", "dist", "output", "node_modules", "assets-local", "backups"],
  "excludedPaths": ["release/rc1-source-lock.json"],
  "excludedSuffixes": [".bin", ".elf", ".map", ".log", ".pcm", ".wav", ".mp3", ".aac", ".m4a", ".png", ".jpg", ".jpeg", ".gif", ".webp", ".ppm", ".tar"],
  "strictGeneratedRoots": ["firmware/generated", "renderer/generated", "runtime/generated"],
  "allowedBinarySources": ["third_party/fonts/inter/InterVariable.ttf"],
  "generatorChecks": [
    ["python3", "scripts/generate-inter-font.py", "--check"],
    ["python3", "scripts/generate-kiara-sprite.py", "--check"],
    ["scripts/generate-renderer-contract.mjs"],
    ["scripts/generate-resolver-traces.mjs"],
    ["scripts/generate-persistence-traces.mjs"],
    ["scripts/generate-network-traces.mjs"],
    ["scripts/generate-firmware-assets.mjs", "--check"],
    ["scripts/generate-firmware-service-vectors.mjs", "--check"],
    ["scripts/generate-runtime-contract.mjs", "--check"],
    ["scripts/generate-ingress-contract.mjs", "--check"]
  ],
  "generatedOwnership": [
    {"generator": "scripts/generate-inter-font.py", "outputs": ["renderer/generated/inter_font.hpp"]},
    {"generator": "scripts/generate-kiara-sprite.py", "outputs": ["renderer/generated/kiara_sprite.hpp"]},
    {"generator": "scripts/generate-renderer-contract.mjs", "outputs": ["renderer/generated/fixture_now_playing.hpp", "renderer/generated/icon_masks.hpp", "renderer/generated/ui_contract.hpp"]},
    {"generator": "scripts/generate-resolver-traces.mjs", "outputs": ["ui-contract/fixtures/resolver-traces.json"]},
    {"generator": "scripts/generate-persistence-traces.mjs", "outputs": ["ui-contract/fixtures/persistence-traces.json"]},
    {"generator": "scripts/generate-network-traces.mjs", "outputs": ["ui-contract/fixtures/network-traces.json"]},
    {"generator": "scripts/generate-firmware-assets.mjs", "outputs": ["firmware/generated/assets-manifest.json", "firmware/generated/onboarding_assets.hpp", "firmware/generated/station_catalog.hpp"]},
    {"generator": "scripts/generate-firmware-service-vectors.mjs", "outputs": ["firmware/generated/service-vectors-manifest.json", "firmware/generated/service_golden_vectors.hpp"]},
    {"generator": "scripts/generate-runtime-contract.mjs", "outputs": ["firmware/generated/runtime-contract-manifest.json", "firmware/generated/runtime_limits.hpp", "firmware/generated/runtime_soak_vectors.hpp", "runtime/generated/runtime-limits.mjs", "ui-contract/fixtures/runtime-soaks.json"]},
    {"generator": "scripts/generate-ingress-contract.mjs", "outputs": ["firmware/generated/runtime-ingress-manifest.json", "firmware/generated/runtime_ingress_limits.hpp", "firmware/generated/runtime_ingress_vectors.hpp", "runtime/generated/ingress-limits.mjs", "ui-contract/fixtures/callback-traces.json"]}
  ]
}
